  \n    // Median\n    double median;\n    if (sorted_numbers.size() % 2 == 0) {\n        median = (sorted_numbers[sorted_numbers.size() / 2 - 1] + \n                  sorted_numbers[sorted_numbers.size() / 2]) / 2.0;\n    } else {\n        median = sorted_numbers[sorted_numbers.size() / 2];\n    }\n    std::cout << \"Median value: \" << median << \"\\n\";\n    \n    return 0;\n}",

#!/usr/bin/env bash
set -euo pipefail

if git diff --cached --name-only | grep -qE '(^|/)\.env$'; then
    echo "ERROR: refusing to commit .env"
    exit 1
fi

if git diff --cached -U0 | grep -qE '^\+.*sk-ant-[A-Za-z0-9_-]+'; then
    echo "ERROR: looks like an Anthropic API key is being added"
    exit 1
fi

STAGED_RS=$(git diff --cached --name-only | grep -E '\.rs$' || true)
if [[ -n "$STAGED_RS" ]]; then
    if ! cargo fmt -- --check; then
        echo "ERROR: code not formatted. Run 'cargo fmt' before committing."
        exit 1
    fi
fi